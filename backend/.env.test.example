# Test Environment Configuration
NODE_ENV=test

# Test Database (separate from dev/prod)
# Adjust host, port, user, and password for your local PostgreSQL setup.
TEST_DATABASE_URL=postgresql://postgres@localhost:5433/gottado_test
ADMIN_DATABASE_URL=postgresql://postgres@localhost:5433/postgres

# JWT Secret (test only)
JWT_SECRET=test-jwt-secret-not-for-production

# Disable external services in tests
SEND_EMAILS=false
UPLOAD_PATH=./uploads/test

# Test-specific settings
LOG_LEVEL=error
